# ===== DeepSeek API =====
# Obtén tu API key en https://platform.deepseek.com/api_keys
# Cópiala sin las comillas:
DEEPSEEK_API_KEY=tu-clave-deepseek-aqui

# ===== Vercel Postgres =====
# Vercel las inyecta automáticamente al crear la BD desde el dashboard.
# En desarrollo local, cópialas desde el dashboard (Connect .env.local).
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_HOST=

# ===== App =====
# Dominio público de tu deploy (sin slash final). Usado para URLs compartibles.
NEXT_PUBLIC_APP_URL=http://localhost:3000
