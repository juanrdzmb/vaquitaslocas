# DeepSeek (obligatorio)
DEEPSEEK_API_KEY=tu-clave-deepseek-aqui

# Modelo opcional. deepseek-v4-flash es el valor por defecto.
DEEPSEEK_MODEL=deepseek-v4-flash

# Neon Postgres (obligatorio en Vercel; la integración lo inyecta)
DATABASE_URL=postgresql://usuario:password@host/base?sslmode=require

# Compatibilidad con proyectos antiguos de Vercel Postgres migrados a Neon.
# POSTGRES_URL=

# URL pública opcional para documentación/operaciones.
NEXT_PUBLIC_APP_URL=http://localhost:3000
